chn_prim 1.0

SYMBOL input_pin
  desc: Input port (hierarchical)

  pins [1]:
    p  in

  params [1]:
    lab = ""

  drawing:
    lines:
      # Short stub from connection point
      (0,0) (-4,0)
      # Pentagon arrow pointing RIGHT (tip near pin = "signal enters here")
      (-4,0) (-10,-6)
      (-10,-6) (-22,-6)
      (-22,-6) (-22,6)
      (-22,6) (-10,6)
      (-10,6) (-4,0)
    text: (-13,0) "@lab"
    pin_positions:
      p: (0,0)
