chn_prim 1.0

SYMBOL capacitor
  desc: Ideal capacitor

  pins [2]:
    p  inout
    n  inout

  params [2]:
    c  = 1p
    ic = 0

  spice_prefix: C
  spice_format: "@name @p @n @c ic=@ic"

  drawing:
    lines:
      # Top lead
      (0,-30) (0,-5)
      # Top plate
      (-10,-5) (10,-5)
      # Bottom plate
      (-10,5) (10,5)
      # Bottom lead
      (0,5) (0,30)
    text: (18,0) "@name"
    text: (18,10) "@c"
    pin_positions:
      p: (0,-30)
      n: (0,30)
