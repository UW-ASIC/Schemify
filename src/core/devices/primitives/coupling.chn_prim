chn_prim 1.0

SYMBOL coupling
  desc: Mutual inductance coupling (K-element)

  pins [0]:

  params [3]:
    L1 = L1
    L2 = L2
    K  = 1

  spice_prefix: K
  spice_format: "@name @L1 @L2 @K"

  drawing:
    lines:
      # Two parallel coil symbols
      (-10,-15) (-10,15)
      (10,-15) (10,15)
      # Coupling arrow
      (-5,0) (5,0)
      (2,3) (5,0)
      (2,-3) (5,0)
    text: (0,-20) "@name"
    text: (0,20) "K=@K"
    pin_positions:
