chn_prim 1.0

SYMBOL iswitch
  desc: Current-controlled switch

  pins [2]:
    p  inout
    n  inout

  params [2]:
    model = CSW
    vsrc  = V0

  spice_prefix: W
  spice_format: "@name @p @n @vsrc @model"

  drawing:
    lines:
      # Switch terminals
      (0,-30) (0,-10)
      (0,10) (0,30)
      # Open switch arm
      (0,-10) (8,8)
    circle: (0,-10) r=2
    circle: (0,10) r=2
    text: (15,0) "@name"
    pin_positions:
      p: (0,-30)
      n: (0,30)
