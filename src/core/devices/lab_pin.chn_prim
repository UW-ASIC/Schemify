chn_prim 1.0

SYMBOL lab_pin
  desc: Label / net name pin

  pins [1]:
    p  inout

  params [1]:
    lab = ""

  drawing:
    lines:
      # Pin stub
      (0,0) (10,0)
      # Label flag shape (larger for visibility)
      (10,-8) (10,8)
      (10,8) (30,8)
      (30,8) (38,0)
      (30,-8) (38,0)
      (10,-8) (30,-8)
    text: (20,0) "@lab"
    pin_positions:
      p: (0,0)
