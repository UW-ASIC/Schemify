{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/UWASIC/Schemify/plugins/CircuitVision/schemas/circuit_graph.schema.json",
    "title": "CircuitGraph",
    "description": "Bridge format between CircuitVision AI pipeline and Schemify editor",
    "type": "object",
    "required": ["version", "metadata", "components", "nets"],
    "properties": {
        "version": {
            "type": "string",
            "const": "1.0"
        },
        "metadata": {
            "type": "object",
            "required": ["detected_style", "pipeline_version"],
            "properties": {
                "source_image": { "type": "string" },
                "detected_style": {
                    "type": "string",
                    "enum": ["handdrawn", "textbook", "datasheet", "unknown"]
                },
                "overall_confidence": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0
                },
                "image_dimensions": {
                    "type": "object",
                    "required": ["width", "height"],
                    "properties": {
                        "width": { "type": "integer", "minimum": 1 },
                        "height": { "type": "integer", "minimum": 1 }
                    }
                },
                "crossing_convention": {
                    "type": "string",
                    "enum": ["dot_means_connected", "always_bridged", "ambiguous"]
                },
                "pipeline_version": { "type": "string" }
            }
        },
        "components": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "type", "pins"],
                "properties": {
                    "id": { "type": "string", "pattern": "^comp_\\d{3}$" },
                    "type": {
                        "type": "string",
                        "enum": [
                            "resistor", "capacitor", "inductor", "potentiometer", "fuse",
                            "diode", "led", "zener", "schottky",
                            "npn", "pnp",
                            "nmos", "nmos4", "pmos", "pmos4",
                            "voltage_source", "current_source",
                            "dependent_voltage_source", "dependent_current_source",
                            "ground", "vdd", "vss", "vcc",
                            "opamp", "comparator", "ic_block", "logic_gate",
                            "junction_dot", "crossing_bridge",
                            "off_page_connector", "test_point", "no_connect"
                        ]
                    },
                    "symbol": { "type": "string" },
                    "ref": { "type": ["string", "null"] },
                    "value": { "type": ["string", "null"] },
                    "confidence": {
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                    },
                    "pins": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["id", "name"],
                            "properties": {
                                "id": { "type": "string" },
                                "name": { "type": "string" }
                            }
                        },
                        "minItems": 1
                    },
                    "source_bbox": {
                        "type": "object",
                        "required": ["x", "y", "w", "h"],
                        "properties": {
                            "x": { "type": "integer" },
                            "y": { "type": "integer" },
                            "w": { "type": "integer", "minimum": 1 },
                            "h": { "type": "integer", "minimum": 1 }
                        }
                    },
                    "properties": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                    }
                }
            }
        },
        "nets": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "pins"],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": ["string", "null"] },
                    "pins": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                    }
                }
            }
        },
        "warnings": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["type", "message"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "ambiguous_crossing",
                            "low_confidence_detection",
                            "ocr_uncertain",
                            "unconnected_pin",
                            "duplicate_ref",
                            "mosfet_terminal_ambiguous"
                        ]
                    },
                    "message": { "type": "string" },
                    "location": {
                        "type": "object",
                        "properties": {
                            "x": { "type": "integer" },
                            "y": { "type": "integer" }
                        }
                    },
                    "component_id": { "type": "string" },
                    "confidence": { "type": "number" },
                    "assumed": { "type": "string" }
                }
            }
        }
    }
}
