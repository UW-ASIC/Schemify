chn_prim 1.0

SYMBOL parax_cap

  pins [1]:
    p  in  x=0  y=-10

  params [4]:
    type = parax_cap
    format = @name @pinlist @gnd @value m=@m
    verilog_ignore = true
    template = name=C1 gnd=0 value=4f m=1

  drawing:
    line 0 -10 0 0
    line -5 0 5 0
    line -5 5 5 5
    line 0 5 0 13
    line -3 13 3 13
    line -3 13 0 15
    line 0 15 3 13
    pin_positions:
      p: (0, -10)
