chn_prim 1.0

SYMBOL vsource_pwl

  pins [4]:
    p  inout  x=0  y=-30
    m  inout  x=0  y=30
    cp  in  x=-40  y=-20
    cm  in  x=-40  y=20

  params [3]:
    type = vsource
    format = @name  @@p @@m pwl(1) @@cp @@cm @TABLE
    template = name=E1 TABLE=\\"1 0 2 3\\"

  drawing:
    line -20 -20 -10 -20
    line -15 -25 -15 -15
    line 0 -30 0 30
    arc 0 0 15 270 360
    pin_positions:
      p: (0, -30)
      m: (0, 30)
      cp: (-40, -20)
      cm: (-40, 20)
