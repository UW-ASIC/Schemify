chn_prim 1.0

SYMBOL delay

  pins [2]:
    inp  in  x=-40  y=0
    outp  out  x=40  y=0

  params [3]:
    type = delay_eldo
    format = del@name @pinlist @del
    template = name=d1 del=2e-9

  drawing:
    line -40 0 -30 0
    line -30 -10 -30 10
    line -30 10 30 10
    line 30 -10 30 10
    line -30 -10 30 -10
    line 30 0 40 0
    pin_positions:
      inp: (-40, 0)
      outp: (40, 0)
