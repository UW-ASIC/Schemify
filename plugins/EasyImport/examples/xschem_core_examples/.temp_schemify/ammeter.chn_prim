chn_prim 1.0

SYMBOL ammeter

  pins [2]:
    plus  inout  x=0  y=-30
    minus  inout  x=0  y=30

  params [3]:
    type = ammeter
    format = @name @pinlist 0 @savecurrent
    template = name=Vmeas savecurrent=true spice_ignore=0

  drawing:
    line 0 -30 0 30
    line -8 0 0 10
    line 0 10 8 0
    pin_positions:
      plus: (0, -30)
      minus: (0, 30)
