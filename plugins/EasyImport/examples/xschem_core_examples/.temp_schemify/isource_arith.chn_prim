chn_prim 1.0

SYMBOL isource_arith

  pins [2]:
    p  inout  x=0  y=-30
    m  inout  x=0  y=30

  params [3]:
    type = isource
    format = @name @pinlist CUR=' @CUR '
    template = name=G1 CUR=cos(V(IN))

  drawing:
    line 0 -30 0 -15
    line -10 0 10 0
    line -20 13 -18 5
    line -23 5 -18 5
    line -23 5 -20 13
    line 0 15 0 30
    line -20 -13 -20 5
    arc 0 0 15 270 360
    pin_positions:
      p: (0, -30)
      m: (0, 30)
