chn_prim 1.0

SYMBOL simulator_commands_shown

  pins [0]:

  params [3]:
    type = netlist_commands
    template = name=COMMANDS simulator=ngspice only_toplevel=false value=\\" \\"
    format = tcleval( [if \{[catch \{sim_is_@simulator \} retval] \} \{ return \{\} \} elseif \{$retval\} \{ return \{ @value \} \} else \{ return \{\} \} ])

  drawing:
    line 0 -10 70 -10
    line 0 -10 0 10
