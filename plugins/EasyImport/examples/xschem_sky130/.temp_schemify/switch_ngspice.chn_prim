chn_prim 1.0

SYMBOL switch_ngspice

  pins [4]:
    CP  in  x=-40  y=0
    P  inout  x=0  y=-30
    M  inout  x=0  y=30
    CM  in  x=-40  y=20

  params [3]:
    type = switch
    format = @name @@P @@M @@CP @@CM @model
    template = name=S1 model=SW1 device_model=\\".MODEL SW1 SW + VT=0.9 VH=0.01 + RON=0.01 ROFF=10G \\"

  drawing:
    line 0 10 0 30
    line -10 -10 0 10
    line 0 -30 0 -10
    line -40 0 -5 0
    line -5 -25 -5 -20
    line -8 -23 -3 -23
    line -10 0 -10 20
    line -40 20 -10 20
    line -33 -8 -33 -3
    line -35 -5 -30 -5
    pin_positions:
      CP: (-40, 0)
      P: (0, -30)
      M: (0, 30)
      CM: (-40, 20)
