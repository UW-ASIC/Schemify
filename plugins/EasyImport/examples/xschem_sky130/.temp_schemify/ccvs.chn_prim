chn_prim 1.0

SYMBOL ccvs

  pins [2]:
    p  inout  x=0  y=-30
    m  inout  x=0  y=30

  params [3]:
    type = vcvs
    format = @name @pinlist @vnam @value
    template = name=H1 vnam=v1 value=1

  drawing:
    line 0 -20 20 0
    line -20 0 0 -20
    line -20 0 0 20
    line 0 20 20 0
    line 0 -30 0 30
    line 10 -20 20 -20
    line 15 -25 15 -15
    pin_positions:
      p: (0, -30)
      m: (0, 30)
