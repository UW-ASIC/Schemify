chn_prim 1.0

SYMBOL asrc

  pins [2]:
    p  inout  x=0  y=-30
    m  inout  x=0  y=30

  params [3]:
    type = source
    format = @name @pinlist @function
    template = name=B1 function=\\"v=tanh(v(1))\\"

  drawing:
    line -20 -20 -10 -20
    line -15 -25 -15 -15
    line 0 -30 0 30
    arc 0 0 15 270 360
    pin_positions:
      p: (0, -30)
      m: (0, 30)
