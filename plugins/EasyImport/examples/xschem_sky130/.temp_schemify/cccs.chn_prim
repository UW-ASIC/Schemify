chn_prim 1.0

SYMBOL cccs

  pins [2]:
    p  in  x=0  y=-30
    m  in  x=0  y=30

  params [3]:
    type = vcvs
    format = @name @pinlist @vnam @value
    template = name=F1 vnam=v1 value=1

  drawing:
    line 0 -20 20 0
    line -20 0 0 -20
    line -20 0 0 20
    line 0 20 20 0
    line 0 20 0 30
    line 0 -30 0 -20
    line -5 5 0 10
    line -5 5 5 5
    line 0 10 5 5
    line 0 -5 0 5
    pin_positions:
      p: (0, -30)
      m: (0, 30)
