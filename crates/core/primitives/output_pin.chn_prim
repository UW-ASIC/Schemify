chn_prim 1.0

SYMBOL output_pin
  desc: Output port (hierarchical)

  pins [1]:
    p  out

  params [1]:
    lab = ""

  drawing:
    lines:
      # Short stub from connection point
      (0,0) (-4,0)
      # Pentagon arrow pointing LEFT (tip away from pin = "signal exits here")
      (-4,-6) (-4,6)
      (-4,6) (-14,6)
      (-14,6) (-20,0)
      (-20,0) (-14,-6)
      (-14,-6) (-4,-6)
    text: (-12,0) "@lab"
    pin_positions:
      p: (0,0)
