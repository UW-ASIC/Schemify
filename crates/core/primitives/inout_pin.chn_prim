chn_prim 1.0

SYMBOL inout_pin
  desc: Bidirectional port (hierarchical)

  pins [1]:
    p  inout

  params [1]:
    lab = ""

  drawing:
    lines:
      # Short stub from connection point to hexagon body
      (0,0) (4,0)
      # Compact hexagon — points on both ends (bidirectional)
      (4,0) (10,-6)
      (10,-6) (18,-6)
      (18,-6) (24,0)
      (24,0) (18,6)
      (18,6) (10,6)
      (10,6) (4,0)
    text: (12,0) "@lab"
    pin_positions:
      p: (0,0)
