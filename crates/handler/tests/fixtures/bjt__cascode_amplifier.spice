.title BJT Cascode Amplifier
.model 2N2222 npn(bf=100 is=1e-14 vaf=50)
Vcc vcc 0 12
Vin vin 0 0
Rb1 vcc base_ce 100k
Rb2 base_ce 0 22k
Rb3 vcc base_cb 56k
Rb4 base_cb 0 22k
Cbypass base_cb 0 100u
Cin vin base_ce 1u
Q1 mid base_ce emitter 2N2222
Re emitter 0 470
Q2 vout base_cb mid 2N2222
Rc vcc vout 4.7k
Cout vout output 1u
Rload output 0 10k
.end
