.title 8-bit R-2R DAC
Vdata[0] data[0] 0 0
Vdata[1] data[1] 0 3.3
Vdata[2] data[2] 0 0
Vdata[3] data[3] 0 3.3
Vdata[4] data[4] 0 0
Vdata[5] data[5] 0 3.3
Vdata[6] data[6] 0 0
Vdata[7] data[7] 0 3.3
Rterm n0 0 20k
R2r0 data[0] n0 20k
Rr0 n0 n1 10k
R2r1 data[1] n1 20k
Rr1 n1 n2 10k
R2r2 data[2] n2 20k
Rr2 n2 n3 10k
R2r3 data[3] n3 20k
Rr3 n3 n4 10k
R2r4 data[4] n4 20k
Rr4 n4 n5 10k
R2r5 data[5] n5 20k
Rr5 n5 n6 10k
R2r6 data[6] n6 20k
Rr6 n6 n7 10k
R2r7 data[7] n7 20k
Rout n7 vout 1
Rload vout 0 1meg
.end
