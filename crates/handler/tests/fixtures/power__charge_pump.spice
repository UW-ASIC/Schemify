.title Dickson Charge Pump
.model diode_1v8 D(is=1e-14 n=1.05)
Vdd vdd 0 1.8
Vclk1 phi1 0 0 PULSE(0 1.8 0 0.0000000001 0.0000000001 0.000000005 0.00000001)
Vclk2 phi2 0 0 PULSE(0 1.8 0 0.0000000001 0.0000000001 0.000000005 0.00000001)
D1 vdd n1 diode_1v8
Cp1 n1 phi1 10p
D2 n1 n2 diode_1v8
Cp2 n2 phi2 10p
D3 n2 n3 diode_1v8
Cp3 n3 phi1 10p
D4 n3 vout diode_1v8
Cout vout 0 50p
Rload vout 0 100k
.end
