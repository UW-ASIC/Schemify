.subckt tb_diff_amp

V1 A 0 1.51
V2 B 0 1.5
X1 Z A B diff_amp_cell gain=100 amplitude=5 offset=2.5
**** begin user architecture code


.options savecurrents
.control
  save all
  op
  remzerovec
  write tb_diff_amp.raw
  dc V1 1.1 1.9 0.001
  set appendwrite
  remzerovec
  write tb_diff_amp.raw
  * quit 0
.endc


**** end user architecture code
.ends
**** begin user architecture code

.control
