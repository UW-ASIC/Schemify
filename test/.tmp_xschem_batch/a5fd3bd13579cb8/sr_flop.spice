.subckt sr_flop S Q R VSS
*.PININFO S:I Q:O VSS:I R:I
x1 net3 net4 R VSS flop VTH=VTH VHI=VHI
x2 net6 net3 S VSS flop VTH=VTH VHI=VHI
E2 net2 VSS and(2) net4 VSS net5 VSS 'VTH-0.1' 0.0 'VTH+0.1' VHI
E3 net1 VSS nor(2) net4 VSS net5 VSS 'VTH-0.1' VHI 'VTH+0.1' 0.0
E4 Q VSS or(2) net2 VSS net1 VSS 'VTH-0.1' 0.0 'VTH+0.1' VHI
B5 net6 VSS V=pwl(v( net4 , VSS ), 'VTH-0.1' VHI 'VTH+0.1' 0 )
B1 net5 VSS V=pwl(v( net3 , VSS ), 'VTH-0.1' VHI 'VTH+0.1' 0 )
.ends

