** sch_path: /nix/store/qriw4afhakn3sqg2al06kdyr745hx86w-xschem-3.4.7/share/doc/xschem/examples/poweramp.sch
.subckt poweramp

V1 VPPI net3 dc 'VPP' pwl 0 0 1m 'VPP'
V0 net3 VNNI dc 'VPP' pwl 0 0 1m 'VPP'
R1 OUTM OUTP 8 m=1
E3 REFP VSS IN VSS {gain*0.99}
C3 VSS VNN 100u m=1
R11 net1 VPPI 0.1 m=1
R9 net2 VNNI 0.1 m=1
R19 OUTM FBN 50k m=1
R0 FBN net4 '50k/gain' m=1
x1 FBN VSSX VSS OUTM VPP VNN mos_power_ampli
x0 FB INX VSS OUTP VPP VNN mos_power_ampli
R6 VPP INX 50k m=1
R7 INX VSS 50k m=1
E0 REFM VSS IN VSS {-gain*0.99}
C5 net4 IN 100n ; ic=0 m=1
C6 net5 VSS 100n ; ic=0 m=1
R2 OUTP FB 50k m=1
R3 FB net5 '50k/(gain-2)' m=1
V3 IN_INT net6 dc 0 sin 0 1 {frequ} 1m
R4 VPP VSSX 50k m=1
R5 VSSX VSS 50k m=1
R8 VPP FBN 50k m=1
C4 INX IN 100n ; ic=0 m=1
C1 VSSX VSS 100n ; ic=0 m=1
R10 IN IN_INT 2 m=1
R13 VPP FB 50k m=1
Vin net6 VSS 0
vcurrvpp net1 VPP 0
.save i(vcurrvpp)
vcurrvnn net2 VNN 0
.save i(vcurrvnn)
vcurrvss net3 VSS 0
.save i(vcurrvss)
C2 VPP VSS 100u m=1
.save v(outm)
.save v(outp)
.save v(refp)
.save v(refm)
.save v(in)
.save v(vpp)
.save v(vnn)
**** begin user architecture code



.option ITL4=20000 ITL5=0
vvss vss 0 dc 0
.param VPP=50
.temp 30
.param frequ=15k
.param gain=45
.option savecurrents

** models are generally not free: you must download
** SPICE models for active devices and put them  into the below
** referenced file in simulation directory.
.include "models_poweramp.txt"
.control
save all
op
write poweramp.raw
set appendwrite
tran  2e-7 0.025 uic
* .FOUR 20k v(outm,outp)
* .probe i(*)
save p(r*) p(v*)
write poweramp.raw
quit 0
.endc




**** end user architecture code
.ends

