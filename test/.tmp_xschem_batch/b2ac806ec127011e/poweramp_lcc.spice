** sch_path: /nix/store/qriw4afhakn3sqg2al06kdyr745hx86w-xschem-3.4.7/share/doc/xschem/examples/poweramp_lcc.sch
.subckt poweramp_lcc

V1 net1 net5 dc 50 pwl 0 0 1m 50
V0 net5 net2 dc 50 pwl 0 0 1m 50
R1 OUTM OUTP 8 m=1
E3 REFP VSS IN VSS {gain*0.99}
C3 VSS VNN 100u m=1
R11 net3 net1 0.3 m=1
R9 net4 net2 0.3 m=1
R19 OUTM FBN '100k' m=1
R0 FBN net6 '100k/gain' m=1
R6 VPP INX 100k m=1
R7 INX VSS 100k m=1
E0 REFM VSS IN VSS {-gain*0.99}
C5 net6 IN 100n ; ic=0 m=1
C6 net7 VSS 100n ; ic=0 m=1
R2 OUTP FB '100k' m=1
R3 FB net7 '100k/(gain-2)' m=1
V3 IN_INT net8 dc 0 sin 0 1 {frequ} 1m
R4 VPP VSSX 100k m=1
R5 VSSX VSS 100k m=1
R8 VPP FBN 100k m=1
C4 INX IN 100n ; ic=0 m=1
C1 VSSX VSS 100n ; ic=0 m=1
R10 IN IN_INT 2 m=1
R13 VPP FB 100k m=1
Vin net8 VSS 0
vcurrvpp net3 VPP 0
.save i(vcurrvpp)
vcurrvnn net4 VNN 0
.save i(vcurrvnn)
vcurrvss net5 VSS 0
.save i(vcurrvss)
C2 VPP VSS 100u m=1
.save v(refp)
.save v(refm)
.save v(in)
.save v(vpp)
.save v(vnn)
x0 FB INX VSS OUTP VPP VNN mos_power_ampli
x1 FBN VSSX VSS OUTM VPP VNN mos_power_ampli
**** begin user architecture code



.option ITL4=20000 ITL5=0
vvss vss 0 dc 0
.temp 30

.param frequ=5k
.param gain=45
.option savecurrents

** models are generally not free: you must download
** SPICE models for active devices and put them  into the below
** referenced file in simulation directory.
.include "models_poweramp.txt"
.control
save all
op
write poweramp_lcc.raw
set appendwrite
tran  8e-7 0.02 uic
* .FOUR 20k v(outm,outp)
* .probe i(*)
plot outp outm
save p(r*) p(v*)
write poweramp_lcc.raw
.endc




**** end user architecture code
.ends

