chn 1

SYMBOL test_evaluated_param
  pins:
    A  inout  x=-150  y=0
    Z  inout  x=150  y=0
  params:
    format = @name @pinlist @symname
    template = name=x1 DEL=3
    type = subcircuit

SCHEMATIC
  instances:
    R1  resistor  x=440  y=-230  rot=1  sym=res
      .parameters{ value=expr( 2500 * @DEL )  footprint=1206  device=resistor  m=1 }
    p1  iopin  x=580  y=-230  sym=iopin  sig_type=std_logic
    l1  gnd  x=500  y=-110  sym=gnd
    p2  iopin  x=360  y=-230  flip=1  sym=iopin  sig_type=std_logic
    C1  capacitor  x=500  y=-160  sym=capa
      .parameters{ m=1  value=expr(100f * @DEL )  footprint=1206  device=ceramic capacitor }

  wires:
    500 -230 580 -230 Z
    500 -230 500 -190 Z
    360 -230 410 -230 A
    470 -230 500 -230 Z
    500 -130 500 -110 GND
