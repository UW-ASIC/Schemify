    640 -560 640 -500 minus
    640 -880 640 -860 plus
    210 -750 210 -730 A
    170 -750 210 -750 A
    600 -690 600 -650 0
    600 -750 600 -730 B
    540 -750 540 -730 B
    640 -680 640 -620 im
    640 -800 640 -740 ip
    110 -750 110 -730 net1
    110 -650 600 -650 0
    80 -650 110 -650 0
    110 -670 110 -650 0
    210 -670 210 -650 0
    340 -670 340 -650 0
    540 -670 540 -650 0
    340 -750 340 -730 net2
    340 -750 370 -750 net2
    210 -750 280 -750 A
