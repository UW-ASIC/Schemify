chn 1

SYMBOL and_ngspice
  pins:
    Y  out  x=60  y=0
    A  in  x=-40  y=-20
    B  in  x=-40  y=20
  params:
    format = @name @pinlist @symname ROUT=@ROUT
    template = name=x1 ROUT=1000
    type = subcircuit

SCHEMATIC
  instances:
    p1  ipin  x=80  y=-170  sym=ipin
    p4  opin  x=330  y=-170  sym=opin
    B1  behavioral  x=480  y=-330  flip=1  sym=bsource  VAR=V  FUNC='VCC/2*(1+tanh((min(V(A1),V(B1))-VCC/2)*100))'
    l2  lab_pin  x=330  y=-400  sym=lab_pin  sig_type=std_logic
    l3  lab_pin  x=480  y=-250  sym=lab_pin  sig_type=std_logic
