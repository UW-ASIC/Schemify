    l6  lab_pin  x=140  y=-170  flip=1  sym=lab_pin  sig_type=std_logic
    l7  lab_pin  x=270  y=-170  sym=lab_pin  sig_type=std_logic
    p2  ipin  x=80  y=-110  sym=ipin
    l4  lab_pin  x=140  y=-110  flip=1  sym=lab_pin  sig_type=std_logic
    l8  lab_pin  x=330  y=-460  sym=lab_pin  sig_type=std_logic
    C1  capacitor  x=370  y=-390  sym=parax_cap  gnd=0  value=8f  m=1
    C2  capacitor  x=370  y=-450  sym=parax_cap  gnd=0  value=8f  m=1
    C3  capacitor  x=630  y=-390  sym=parax_cap  gnd=0  value=8f  m=1
    V1  vsource  x=110  y=-170  rot=1  sym=vsource  value=0
    V2  vsource  x=110  y=-110  rot=1  sym=vsource  value=0
    V3  vsource  x=300  y=-170  rot=1  sym=vsource  value=0

