chn_testbench 1

TESTBENCH test_ne555
  instances:
    x1  subckt  x=490  y=-220  sym=ne555  tclcommand=textwindow $netlist_dir/model_test_ne555.txt
    r3  resistor  x=130  y=-180  sym=res  m=1  value=2k
    c6  capacitor  x=130  y=-120  sym=capa  m=1  value=2n
    v1  vsource  x=130  y=-360  flip=1  sym=vsource  value=5
    p16  lab_pin  x=130  y=-330  sym=lab_pin
    p6  lab_pin  x=130  y=-390  flip=1  sym=lab_pin
    p8  lab_pin  x=570  y=-340  flip=1  sym=lab_pin
    p9  lab_pin  x=410  y=-340  sym=lab_pin
    p11  lab_pin  x=410  y=-260  sym=lab_pin
    p12  lab_pin  x=410  y=-180  sym=lab_pin
    p15  lab_pin  x=570  y=-180  flip=1  sym=lab_pin
    p19  lab_pin  x=200  y=-150  flip=1  sym=lab_pin
    p20  lab_pin  x=130  y=-270  sym=lab_pin
    p21  lab_pin  x=130  y=-90  sym=lab_pin
    p14  lab_pin  x=570  y=-100  flip=1  sym=lab_pin
    p13  lab_pin  x=410  y=-100  sym=lab_pin
    p17  lab_pin  x=570  y=-260  flip=1  sym=lab_pin
    r5  resistor  x=130  y=-240  sym=res  m=1  value=2k
    p18  lab_pin  x=130  y=-210  sym=lab_pin

  nets:
    VSS  -> x1.GND
    TRIG  -> x1.TRIG, x1.THRES
    OUT  -> x1.OUT
    VSUPPLY  -> x1.RESETB, x1.VCC
    CTRL  -> x1.CTRL
    DIS  -> x1.DIS

  wires:
    130 -150 200 -150 TRIG
    570 -130 570 -100 CTRL
