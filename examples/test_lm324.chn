chn_testbench 1

TESTBENCH test_lm324
  instances:
    x1  subckt  x=640  y=-300  sym=lm324
    p10  lab_pin  x=640  y=-200  sym=lab_pin
    p1  lab_pin  x=640  y=-400  sym=lab_pin
    p2  lab_pin  x=960  y=-300  flip=1  sym=lab_pin
    p3  lab_pin  x=520  y=-340  sym=lab_pin
    r1  resistor  x=900  y=-250  sym=res  m=1  value=10k
    c1  capacitor  x=820  y=-250  sym=capa  m=1  value=1n
    p5  lab_pin  x=820  y=-220  sym=lab_pin
    p6  lab_pin  x=900  y=-220  sym=lab_pin

  nets:
    P  -> x1.1
    Q  -> x1.2, x1.5
    VCC  -> x1.3
    VSS  -> x1.4

  wires:
    520 -340 560 -340 P
    640 -400 640 -370 VCC
    640 -230 640 -200 VSS
    770 -300 960 -300 Q
    900 -300 900 -280 Q
    820 -300 820 -280 Q
    770 -300 770 -150 Q
    560 -150 770 -150 Q
    560 -260 560 -150 Q
